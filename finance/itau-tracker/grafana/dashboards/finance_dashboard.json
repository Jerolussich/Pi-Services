  "panels": [
    {
      "id": 1, "type": "stat", "gridPos": {"x":0,"y":0,"w":6,"h":4},
      "title": "Total this month (UYU)",
      "datasource": {"type":"frser-sqlite-datasource","uid":"cfdqep2yn124gf"},
      "options": {"colorMode":"value","graphMode":"none","textMode":"value"},
      "fieldConfig": {"defaults": {"color":{"mode":"thresholds"},"thresholds":{"steps":[{"color":"green","value":null},{"color":"yellow","value":10000},{"color":"red","value":30000}]}}},
      "targets": [{"rawQueryText":"SELECT COALESCE(SUM(amount),0) as value FROM transactions WHERE strftime('%Y-%m', date) = strftime('%Y-%m','now') AND currency = 'UYU'","queryType":"table","refId":"A"}]
    },
    {
      "id": 2, "type": "stat", "gridPos": {"x":6,"y":0,"w":6,"h":4},
      "title": "Transactions this month",
      "datasource": {"type":"frser-sqlite-datasource","uid":"cfdqep2yn124gf"},
      "options": {"colorMode":"value","graphMode":"none"},
      "fieldConfig": {"defaults": {"color":{"mode":"fixed","fixedColor":"blue"}}},
      "targets": [{"rawQueryText":"SELECT COUNT(*) as value FROM transactions WHERE strftime('%Y-%m', date) = strftime('%Y-%m','now')","queryType":"table","refId":"A"}]
    },
    {
      "id": 3, "type": "stat", "gridPos": {"x":12,"y":0,"w":6,"h":4},
      "title": "Avg transaction (UYU)",
      "datasource": {"type":"frser-sqlite-datasource","uid":"cfdqep2yn124gf"},
      "options": {"colorMode":"value","graphMode":"none"},
      "fieldConfig": {"defaults": {"color":{"mode":"fixed","fixedColor":"purple"},"decimals":0}},
      "targets": [{"rawQueryText":"SELECT ROUND(AVG(amount),0) as value FROM transactions WHERE currency='UYU'","queryType":"table","refId":"A"}]
    },
    {
      "id": 4, "type": "stat", "gridPos": {"x":18,"y":0,"w":6,"h":4},
      "title": "Total transactions (all time)",
      "datasource": {"type":"frser-sqlite-datasource","uid":"cfdqep2yn124gf"},
      "options": {"colorMode":"value","graphMode":"none"},
      "fieldConfig": {"defaults": {"color":{"mode":"fixed","fixedColor":"orange"}}},
      "targets": [{"rawQueryText":"SELECT COUNT(*) as value FROM transactions","queryType":"table","refId":"A"}]
    },
    {
      "id": 5, "type": "barchart", "gridPos": {"x":0,"y":4,"w":14,"h":9},
      "title": "Monthly spending (UYU)",
      "datasource": {"type":"frser-sqlite-datasource","uid":"cfdqep2yn124gf"},
      "fieldConfig": {"defaults":{"color":{"mode":"fixed","fixedColor":"blue"}}},
      "options": {"xTickLabelRotation":-45},
      "targets": [{"rawQueryText":"SELECT strftime('%Y-%m', date) as month, ROUND(SUM(amount),2) as total FROM transactions WHERE currency='UYU' GROUP BY month ORDER BY month","queryType":"table","refId":"A"}]
    },
    {
      "id": 6, "type": "piechart", "gridPos": {"x":14,"y":4,"w":10,"h":9},
      "title": "Spending by category (UYU)",
      "datasource": {"type":"frser-sqlite-datasource","uid":"cfdqep2yn124gf"},
      "options": {"pieType":"donut","displayLabels":["name","percent"]},
      "targets": [{"rawQueryText":"SELECT category, ROUND(SUM(amount),2) as total FROM transactions WHERE currency='UYU' GROUP BY category ORDER BY total DESC","queryType":"table","refId":"A"}]
    },
    {
      "id": 7, "type": "barchart", "gridPos": {"x":0,"y":13,"w":12,"h":8},
      "title": "Top merchants (UYU, all time)",
      "datasource": {"type":"frser-sqlite-datasource","uid":"cfdqep2yn124gf"},
      "fieldConfig": {"defaults":{"color":{"mode":"fixed","fixedColor":"orange"}}},
      "options": {"xTickLabelRotation":-45},
      "targets": [{"rawQueryText":"SELECT merchant, ROUND(SUM(amount),2) as total FROM transactions WHERE currency='UYU' GROUP BY merchant ORDER BY total DESC LIMIT 10","queryType":"table","refId":"A"}]
    },
    {
      "id": 8, "type": "table", "gridPos": {"x":12,"y":13,"w":12,"h":8},
      "title": "Recent transactions",
      "datasource": {"type":"frser-sqlite-datasource","uid":"cfdqep2yn124gf"},
      "options": {"sortBy":[{"displayName":"date","desc":true}]},
      "targets": [{"rawQueryText":"SELECT date, merchant, card_type || ' ***' || card_last4 as card, amount, currency, category FROM transactions ORDER BY date DESC LIMIT 25","queryType":"table","refId":"A"}]
    }
  ]
