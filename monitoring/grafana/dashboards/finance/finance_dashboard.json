      "options": { "xTickLabelRotation": -45 },
      "targets": [{ "rawQueryText": "SELECT strftime('%Y-%m', date) as month, ROUND(SUM(amount),2) as total FROM transactions WHERE currency='UYU' GROUP BY month ORDER BY month", "queryType": "table", "refId": "A" }]
    },
